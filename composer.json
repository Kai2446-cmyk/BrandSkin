{
  "name": "glowskin/cosmetic-laravel13",
  "type": "project",
  "description": "GlowSkin cosmetic brand website converted from Next.js frontend to Laravel 13 Blade without changing the visual concept.",
  "require": {
    "php": ">=8.5.1",
    "laravel/framework": "^13.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "laravel/pint": "^1.24"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "platform": { "php": "8.5.1" }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
